# Local-only release config. Copy to `.codexbar-release.local.env` or, preferably,
# store as `~/.codexbar-secrets/codexbar-release.env`.
#
# This file is intentionally not sourced unless it exists locally.

APP_STORE_CONNECT_KEY_ID=YOUR_KEY_ID
APP_STORE_CONNECT_ISSUER_ID=YOUR_ISSUER_ID_UUID
APP_STORE_CONNECT_API_KEY_FILE=$HOME/.codexbar-secrets/AuthKey_YOUR_KEY_ID.p8
SPARKLE_PRIVATE_KEY_FILE=$HOME/.codexbar-secrets/sparkle_ed25519.key
